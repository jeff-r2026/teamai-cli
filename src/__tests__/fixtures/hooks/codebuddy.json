    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc \"teamai hook-dispatch prompt-submit --tool codebuddy 2>/dev/null\" || true"
          }
        ],
        "description": "[teamai] Hook dispatch prompt-submit"
      }
    ]
  }
}
